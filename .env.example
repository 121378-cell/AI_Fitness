# AI Fitness Dashboard Configuration Example

# File Paths
SAVE_PATH=/path/to/AI_Fitness_Data
DRIVE_MOUNT_PATH=/path/to/GDrive

# Garmin Connect
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password


# AI Providers (ordered fallback)
AI_PROVIDER_ORDER=ollama,groq,gemini

# Ollama (primary)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# Groq (fallback)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-70b-versatile

# Gemini (fallback)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest

# Google Services
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# System Settings
CHECK_MOUNT_STATUS=True
FLASK_SECRET_KEY=change_this_secret
DASHBOARD_PORT=8501
AI_FITNESS_LOG_LEVEL=INFO
